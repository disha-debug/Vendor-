# Supabase (required for app)
# Get these from: Supabase Dashboard → Project Settings → API
# For Vercel: add these in Project Settings → Environment Variables (Production, Preview, Development).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# Optional: for local Supabase CLI (not used by frontend)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# ⚠️ Never add SUPABASE_SERVICE_ROLE_KEY to frontend env. Use only in backend/server.

# ---------------------------------------------------------------------------
# Supabase Auth redirect URLs (Supabase Dashboard → Authentication → URL Configuration)
# Add these to "Redirect URLs" so auth works after login/signup:
#   - https://yourdomain.vercel.app
#   - https://yourdomain.vercel.app/**
#   - http://localhost:5173
#   - http://localhost:8080
# ---------------------------------------------------------------------------
